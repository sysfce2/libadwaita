<?xml version="1.0" encoding="UTF-8"?>
<app xmlns="https://sp1rit.arpa/pixiewood/" xmlns:xi="http://www.w3.org/2001/XInclude">
  <metainfo target="demo/data/org.gnome.Adwaita1.Demo.metainfo.xml">
    <xi:include href="build://aarch64/demo/data/org.gnome.Adwaita1.Demo.metainfo.xml" parse="xml"/>
  </metainfo>
  <style>
    <theme name="adw"/>
    <icon type="generate">
      <drawable target="foreground" scale=".66" type="svg" path="src://build-aux/android/foreground.svg"/>
      <drawable target="background" type="svg" path="src://build-aux/android/background.svg"/>
      <drawable target="monochrome" scale=".45" type="svg" path="src://demo/data/org.gnome.Adwaita1.Demo-symbolic.svg"/>
    </icon>
  </style>
  <dependencies>
    <glib>
      <patch>hack</patch>
    </glib>
  </dependencies>
  <build target="adwaita-1-demo">
    <configure-options>
      <option>-Dintrospection=disabled</option>
      <option>-Dtests=false</option>
      <option>-Dexamples=true</option>
      <option>-Dgtk:media-gstreamer=disabled</option>
    </configure-options>
  </build>
</app>
